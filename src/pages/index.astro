---
import Page from '../layouts/Page.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const projects = (await getCollection('portfolio'))
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

// Add your hero images here — drop files into public/images/hero/
// and list their filenames below.
const heroImages = [
  // '/christiandreyer.no/images/hero/photo1.jpg',
  // '/christiandreyer.no/images/hero/photo2.jpg',
];
const hasHeroImages = heroImages.length > 0;
---

<Page title="Christian Dreyer" description="Engineer — fluid mechanics, thermal systems, and computational methods.">
  <div class="max-w-3xl mx-auto px-6">

    <!-- Hero -->
    <section class="pt-16 pb-16">

      {hasHeroImages && (
        <div id="hero-image" class="w-full aspect-[16/7] rounded-2xl overflow-hidden bg-zinc-100 dark:bg-zinc-900 mb-10">
          <img id="hero-img-el" src="" alt="Christian Dreyer" class="w-full h-full object-cover transition-opacity duration-700" />
        </div>
      )}

      <p class="section-label mb-5">Engineer · Norway</p>
      <h1 class="text-4xl sm:text-5xl font-semibold text-zinc-900 dark:text-zinc-100 tracking-tight mb-6 leading-tight">
        Christian Dreyer
      </h1>
      <p class="text-xl text-zinc-600 dark:text-zinc-400 leading-relaxed max-w-lg">
        I work on fluid mechanics, thermal systems, and computational methods.
      </p>

      <div class="flex flex-wrap gap-3 mt-8">
        <a href={`${base}/cv`} class="btn-primary">View CV</a>
        <a href="mailto:christian.sorbu@gmail.com" class="btn-ghost">Get in touch</a>
      </div>
    </section>

    <div class="divider"></div>

    <!-- Navigation cards -->
    <section class="py-14">
      <p class="section-label mb-6">Explore</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">

        <a href={`${base}/cv`} class="card group">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-8 h-8 rounded-lg bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center text-zinc-600 dark:text-zinc-400 group-hover:bg-zinc-200 dark:group-hover:bg-zinc-700 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25Z"/>
              </svg>
            </div>
            <h2 class="font-semibold text-zinc-900 dark:text-zinc-100">CV</h2>
          </div>
          <p class="text-sm text-zinc-500 dark:text-zinc-400">Education, experience, and skills.</p>
        </a>

        <a href={`${base}/portfolio`} class="card group">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-8 h-8 rounded-lg bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center text-zinc-600 dark:text-zinc-400 group-hover:bg-zinc-200 dark:group-hover:bg-zinc-700 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.429 9.75 2.25 12l4.179 2.25m0-4.5 5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0 4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0-5.571 3-5.571-3"/>
              </svg>
            </div>
            <h2 class="font-semibold text-zinc-900 dark:text-zinc-100">Portfolio</h2>
          </div>
          <p class="text-sm text-zinc-500 dark:text-zinc-400">Projects, pictures, and written work.</p>
        </a>

        <a href={`${base}/writing`} class="card group">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-8 h-8 rounded-lg bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center text-zinc-600 dark:text-zinc-400 group-hover:bg-zinc-200 dark:group-hover:bg-zinc-700 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10"/>
              </svg>
            </div>
            <h2 class="font-semibold text-zinc-900 dark:text-zinc-100">Writing</h2>
          </div>
          <p class="text-sm text-zinc-500 dark:text-zinc-400">Notes on engineering and tools.</p>
        </a>

        <a href={`${base}/about`} class="card group">
          <div class="flex items-center gap-3 mb-2">
            <div class="w-8 h-8 rounded-lg bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center text-zinc-600 dark:text-zinc-400 group-hover:bg-zinc-200 dark:group-hover:bg-zinc-700 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/>
              </svg>
            </div>
            <h2 class="font-semibold text-zinc-900 dark:text-zinc-100">About</h2>
          </div>
          <p class="text-sm text-zinc-500 dark:text-zinc-400">A bit more about me.</p>
        </a>

      </div>
    </section>

    <!-- Recent writing -->
    {posts.length > 0 && (
      <section class="py-14 border-t border-zinc-200 dark:border-zinc-800">
        <div class="flex items-center justify-between mb-8">
          <p class="section-label">Recent writing</p>
          <a href={`${base}/writing`} class="text-sm text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors">All posts →</a>
        </div>
        <div class="space-y-6">
          {posts.map((post) => (
            <a href={`${base}/writing/${post.slug}`} class="group block">
              <div class="flex items-baseline justify-between gap-4">
                <h3 class="font-medium text-zinc-900 dark:text-zinc-100 group-hover:text-zinc-600 dark:group-hover:text-zinc-400 transition-colors">
                  {post.data.title}
                </h3>
                <time class="text-sm text-zinc-400 flex-shrink-0">
                  {post.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'short' })}
                </time>
              </div>
              <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">{post.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Featured projects -->
    {projects.length > 0 && (
      <section class="py-14 border-t border-zinc-200 dark:border-zinc-800">
        <div class="flex items-center justify-between mb-8">
          <p class="section-label">Featured projects</p>
          <a href={`${base}/portfolio`} class="text-sm text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors">All projects →</a>
        </div>
        <div class="space-y-3">
          {projects.map((project) => (
            <a href={`${base}/portfolio/${project.slug}`} class="card group block">
              <h3 class="font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-zinc-600 dark:group-hover:text-zinc-400 transition-colors mb-1.5">
                {project.data.title}
              </h3>
              <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-3">{project.data.description}</p>
              <div class="flex flex-wrap gap-1.5">
                {project.data.tags.map(tag => <span class="tag">{tag}</span>)}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>
</Page>

{hasHeroImages && (
  <script define:vars={{ heroImages }}>
    // Pick image based on current hour — changes once per hour, same for all visitors
    const img = document.getElementById('hero-img-el');
    if (img) {
      const hour = new Date().getHours();
      const index = hour % heroImages.length;
      img.src = heroImages[index];
      img.style.opacity = '0';
      img.onload = () => { img.style.opacity = '1'; };
    }
  </script>
)}
