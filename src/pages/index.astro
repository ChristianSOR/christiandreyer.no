---
import Page from '../layouts/Page.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const projects = (await getCollection('portfolio'))
  .filter(p => p.data.featured)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const sections = [
  {
    href: '/cv',
    label: 'CV',
    description: 'Education, experience, and skills.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z"/>`,
  },
  {
    href: '/portfolio',
    label: 'Portfolio',
    description: 'Projects, tools, and simulations.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M6.429 9.75 2.25 12l4.179 2.25m0-4.5 5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0 4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0-5.571 3-5.571-3"/>`,
  },
  {
    href: '/writing',
    label: 'Writing',
    description: 'Notes on engineering and tools.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10"/>`,
  },
  {
    href: '/about',
    label: 'About',
    description: 'A bit more about me.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/>`,
  },
];
---

<Page title="Christian Dreyer" description="Engineer — fluid mechanics, thermal systems, and computational methods.">
  <div class="max-w-3xl mx-auto px-6">

    <!-- Hero -->
    <section class="pt-20 pb-16 animate-fade-in">
      <p class="section-label mb-4">Engineer</p>
      <h1 class="text-3xl sm:text-4xl font-semibold text-stone-900 dark:text-stone-100 tracking-tight mb-5">
        Christian Dreyer
      </h1>
      <p class="text-lg text-stone-600 dark:text-stone-400 leading-relaxed max-w-xl">
        <!-- Edit your intro here -->
        I work on fluid mechanics, thermal systems, and computational methods.
        Interested in the intersection of physical intuition and modern software tools.
      </p>

      <div class="flex flex-wrap gap-3 mt-8">
        <a href="/cv" class="btn-primary">View CV</a>
        <a href="mailto:christian@christiandreyer.no" class="btn-ghost">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
          Get in touch
        </a>
      </div>
    </section>

    <div class="divider"></div>

    <!-- Navigation cards -->
    <section class="py-16 animate-slide-up">
      <p class="section-label mb-8">Explore</p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {sections.map(({ href, label, description, icon }) => (
          <a href={href} class="card group flex items-start gap-4">
            <div class="flex-shrink-0 mt-0.5 text-stone-400 dark:text-stone-500 group-hover:text-stone-700 dark:group-hover:text-stone-300 transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" set:html={icon} />
            </div>
            <div>
              <h2 class="font-semibold text-stone-900 dark:text-stone-100 group-hover:text-stone-700 dark:group-hover:text-stone-300 transition-colors mb-1">
                {label}
              </h2>
              <p class="text-sm text-stone-500 dark:text-stone-400">{description}</p>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Recent writing -->
    {posts.length > 0 && (
      <section class="py-16 border-t border-stone-200 dark:border-stone-800">
        <div class="flex items-center justify-between mb-8">
          <p class="section-label">Recent writing</p>
          <a href="/writing" class="text-sm text-stone-500 dark:text-stone-400 hover:text-stone-800 dark:hover:text-stone-200 transition-colors">
            All posts →
          </a>
        </div>
        <div class="space-y-6">
          {posts.map((post) => (
            <a href={`/writing/${post.slug}`} class="group block">
              <div class="flex items-baseline justify-between gap-4">
                <h3 class="text-stone-800 dark:text-stone-200 group-hover:text-stone-600 dark:group-hover:text-stone-400 transition-colors font-medium">
                  {post.data.title}
                </h3>
                <time class="text-sm text-stone-400 dark:text-stone-500 flex-shrink-0">
                  {post.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'short' })}
                </time>
              </div>
              <p class="text-sm text-stone-500 dark:text-stone-400 mt-1">{post.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Featured projects -->
    {projects.length > 0 && (
      <section class="py-16 border-t border-stone-200 dark:border-stone-800">
        <div class="flex items-center justify-between mb-8">
          <p class="section-label">Featured projects</p>
          <a href="/portfolio" class="text-sm text-stone-500 dark:text-stone-400 hover:text-stone-800 dark:hover:text-stone-200 transition-colors">
            All projects →
          </a>
        </div>
        <div class="space-y-4">
          {projects.map((project) => (
            <a href={`/portfolio/${project.slug}`} class="card group block">
              <h3 class="font-semibold text-stone-900 dark:text-stone-100 group-hover:text-stone-600 dark:group-hover:text-stone-400 transition-colors mb-1">
                {project.data.title}
              </h3>
              <p class="text-sm text-stone-500 dark:text-stone-400 mb-3">{project.data.description}</p>
              <div class="flex flex-wrap gap-2">
                {project.data.tags.map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>
</Page>
