---
import Page from '../layouts/Page.astro';
---

<Page title="404 — Page not found">
  <div class="max-w-3xl mx-auto px-6 py-32 text-center">
    <p class="text-7xl font-semibold text-stone-200 dark:text-stone-800 mb-6 select-none">404</p>
    <h1 class="text-xl font-semibold text-stone-900 dark:text-stone-100 mb-3">Page not found</h1>
    <p class="text-stone-500 dark:text-stone-400 mb-8">This page doesn't exist or has been moved.</p>
    <a href="/" class="btn-primary">Go home</a>
  </div>
</Page>
