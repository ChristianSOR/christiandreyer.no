---
import Page from '../../layouts/Page.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Page title="Writing" description="Notes on engineering, tools, and methods by Christian Dreyer.">
  <div class="max-w-3xl mx-auto px-6 py-16">

    <p class="section-label mb-4">Writing</p>
    <h1 class="text-3xl font-semibold text-zinc-900 dark:text-zinc-100 tracking-tight mb-10">Notes</h1>

    {posts.length === 0 ? (
      <p class="text-zinc-500 dark:text-zinc-400">No posts yet.</p>
    ) : (
      <div class="divide-y divide-zinc-100 dark:divide-zinc-800">
        {posts.map((post) => (
          <a href={`${base}/writing/${post.slug}`} class="group flex items-start justify-between gap-8 py-6 block">
            <div>
              <h2 class="font-medium text-zinc-900 dark:text-zinc-100 group-hover:text-zinc-600 dark:group-hover:text-zinc-400 transition-colors mb-1.5">
                {post.data.title}
              </h2>
              <p class="text-sm text-zinc-600 dark:text-zinc-400 leading-relaxed">{post.data.description}</p>
              {post.data.tags.length > 0 && (
                <div class="flex flex-wrap gap-1.5 mt-3">
                  {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
                </div>
              )}
            </div>
            <time class="text-sm text-zinc-400 dark:text-zinc-500 flex-shrink-0 pt-0.5">
              {post.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
        ))}
      </div>
    )}

  </div>
</Page>
