---
import Page from '../../layouts/Page.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('writing', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = await getEntry('writing', slug!);

if (!post) return Astro.redirect('/writing');

const { Content } = await post.render();

const readingTime = Math.ceil(post.body.split(/\s+/).length / 200);
---

<Page
  title={post.data.title}
  description={post.data.description}
>
  <div class="max-w-3xl mx-auto px-6 py-16">

    <a href="/writing" class="inline-flex items-center gap-1.5 text-sm text-stone-500 dark:text-stone-400 hover:text-stone-800 dark:hover:text-stone-200 transition-colors mb-10">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m15 18-6-6 6-6"/>
      </svg>
      Writing
    </a>

    <header class="mb-12">
      <div class="flex flex-wrap gap-1.5 mb-5">
        {post.data.tags.map(tag => (
          <span class="tag">{tag}</span>
        ))}
      </div>

      <h1 class="text-3xl sm:text-4xl font-semibold text-stone-900 dark:text-stone-100 tracking-tight leading-tight mb-5">
        {post.data.title}
      </h1>

      <p class="text-lg text-stone-500 dark:text-stone-400 mb-6">{post.data.description}</p>

      <div class="flex items-center gap-4 text-sm text-stone-400 dark:text-stone-500">
        <time>
          {post.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        <span>&middot;</span>
        <span>{readingTime} min read</span>
      </div>
    </header>

    <div class="divider mb-12"></div>

    <article class="prose prose-stone dark:prose-invert max-w-none
                    prose-headings:font-semibold prose-headings:tracking-tight
                    prose-a:underline prose-a:underline-offset-2
                    prose-code:text-sm prose-pre:text-sm
                    prose-img:rounded-lg">
      <Content />
    </article>

  </div>
</Page>
