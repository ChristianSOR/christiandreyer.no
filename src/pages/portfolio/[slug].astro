---
import Page from '../../layouts/Page.astro';
import { getCollection, getEntry } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

export async function getStaticPaths() {
  const projects = await getCollection('portfolio');
  return projects.map(project => ({ params: { slug: project.slug } }));
}

const { slug } = Astro.params;
const project = await getEntry('portfolio', slug!);
if (!project) return Astro.redirect(`${import.meta.env.BASE_URL}portfolio`);

const { Content } = await project.render();
---

<Page title={project.data.title} description={project.data.description}>
  <div class="max-w-3xl mx-auto px-6 py-16">

    <a href={`${base}/portfolio`} class="inline-flex items-center gap-1.5 text-sm text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 transition-colors mb-10">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m15 18-6-6 6-6"/>
      </svg>
      Portfolio
    </a>

    {project.data.image && (
      <div class="aspect-video rounded-xl overflow-hidden bg-zinc-100 dark:bg-zinc-800 mb-10">
        <img src={project.data.image} alt={project.data.title} class="w-full h-full object-cover" />
      </div>
    )}

    <header class="mb-10">
      <div class="flex flex-wrap gap-1.5 mb-4">
        {project.data.tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
      <h1 class="text-3xl font-semibold text-zinc-900 dark:text-zinc-100 tracking-tight mb-3">
        {project.data.title}
      </h1>
      <p class="text-zinc-600 dark:text-zinc-400">{project.data.description}</p>

      <div class="flex flex-wrap gap-3 mt-6">
        {project.data.link && (
          <a href={project.data.link} target="_blank" rel="noopener noreferrer" class="btn-primary">
            View project
          </a>
        )}
        {project.data.github && (
          <a href={project.data.github} target="_blank" rel="noopener noreferrer" class="btn-ghost">
            Source code
          </a>
        )}
      </div>
    </header>

    <div class="divider mb-10"></div>

    <article class="prose prose-zinc dark:prose-invert max-w-none">
      <Content />
    </article>

  </div>
</Page>
