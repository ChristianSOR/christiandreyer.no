---
import Page from '../../layouts/Page.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('portfolio'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(projects.flatMap(p => p.data.tags))].sort();
---

<Page
  title="Portfolio"
  description="Projects, tools, and simulations by Christian Dreyer."
>
  <div class="max-w-3xl mx-auto px-6 py-16">

    <p class="section-label mb-4">Portfolio</p>
    <h1 class="text-3xl font-semibold text-stone-900 dark:text-stone-100 tracking-tight mb-10">
      Projects
    </h1>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {projects.map((project) => (
        <a href={`/portfolio/${project.slug}`} class="card group flex flex-col">
          {project.data.image && (
            <div class="aspect-video rounded-md overflow-hidden bg-stone-100 dark:bg-stone-800 mb-4 -mx-2 -mt-2">
              <img
                src={project.data.image}
                alt={project.data.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            </div>
          )}

          <div class="flex-1">
            <h2 class="font-semibold text-stone-900 dark:text-stone-100 group-hover:text-stone-600 dark:group-hover:text-stone-400 transition-colors mb-1.5">
              {project.data.title}
            </h2>
            <p class="text-sm text-stone-500 dark:text-stone-400 mb-4 leading-relaxed">
              {project.data.description}
            </p>
          </div>

          <div class="flex flex-wrap gap-1.5">
            {project.data.tags.slice(0, 4).map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>

  </div>
</Page>
