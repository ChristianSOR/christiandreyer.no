---
import Page from '../../layouts/Page.astro';
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const all = (await getCollection('portfolio'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const projects = all.filter(p => p.data.category === 'project');
const personal = all.filter(p => p.data.category === 'personal');
const writing  = all.filter(p => p.data.category === 'writing');
---

<Page title="Portfolio" description="Projects, personal pictures, and writing by Christian Dreyer.">
  <div class="max-w-3xl mx-auto px-6 py-16">

    <p class="section-label mb-4">Portfolio</p>
    <h1 class="text-3xl font-semibold text-zinc-900 dark:text-zinc-100 tracking-tight mb-14">Work &amp; life</h1>

    <!-- Projects -->
    <section class="mb-16">
      <h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 mb-6">Projects</h2>
      {projects.length === 0 ? (
        <p class="text-sm text-zinc-400 dark:text-zinc-500">No projects yet.</p>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {projects.map((project) => (
            <a href={`${base}/portfolio/${project.slug}`} class="card group flex flex-col">
              {project.data.image && (
                <div class="aspect-video rounded-lg overflow-hidden bg-zinc-100 dark:bg-zinc-800 mb-4">
                  <img src={project.data.image} alt={project.data.title}
                       class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                </div>
              )}
              <div class="flex-1">
                <h3 class="font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-zinc-600 dark:group-hover:text-zinc-400 transition-colors mb-1.5">
                  {project.data.title}
                </h3>
                <p class="text-sm text-zinc-600 dark:text-zinc-400 mb-4 leading-relaxed">{project.data.description}</p>
              </div>
              <div class="flex flex-wrap gap-1.5">
                {project.data.tags.slice(0, 4).map(tag => <span class="tag">{tag}</span>)}
              </div>
            </a>
          ))}
        </div>
      )}
    </section>

    <div class="divider mb-16"></div>

    <!-- Personal pictures -->
    <section class="mb-16">
      <h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 mb-6">Personal</h2>
      {personal.length === 0 ? (
        <p class="text-sm text-zinc-400 dark:text-zinc-500">No photos yet.</p>
      ) : (
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
          {personal.map((item) => (
            <a href={`${base}/portfolio/${item.slug}`} class="group block aspect-square rounded-xl overflow-hidden bg-zinc-100 dark:bg-zinc-800">
              {item.data.image ? (
                <img src={item.data.image} alt={item.data.title}
                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
              ) : (
                <div class="w-full h-full flex items-center justify-center text-zinc-400 dark:text-zinc-600 text-xs">
                  {item.data.title}
                </div>
              )}
            </a>
          ))}
        </div>
      )}
    </section>

    <div class="divider mb-16"></div>

    <!-- Written stuff -->
    <section>
      <h2 class="text-lg font-semibold text-zinc-900 dark:text-zinc-100 mb-6">Written work</h2>
      {writing.length === 0 ? (
        <p class="text-sm text-zinc-400 dark:text-zinc-500">No written work yet.</p>
      ) : (
        <div class="space-y-3">
          {writing.map((item) => (
            <a href={`${base}/portfolio/${item.slug}`} class="card group flex items-start gap-4">
              {item.data.image && (
                <div class="w-16 h-16 rounded-lg overflow-hidden bg-zinc-100 dark:bg-zinc-800 flex-shrink-0">
                  <img src={item.data.image} alt={item.data.title} class="w-full h-full object-cover" loading="lazy" />
                </div>
              )}
              <div>
                <h3 class="font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-zinc-600 dark:group-hover:text-zinc-400 transition-colors mb-1">
                  {item.data.title}
                </h3>
                <p class="text-sm text-zinc-600 dark:text-zinc-400">{item.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      )}
    </section>

  </div>
</Page>
