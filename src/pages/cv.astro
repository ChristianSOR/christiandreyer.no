---
import Page from '../layouts/Page.astro';
import { cv } from '../data/cv';
---

<Page title="CV" description="CV of Christian Dreyer — education, experience, and skills.">
  <div class="max-w-3xl mx-auto px-6 py-16">

    <div class="flex items-start justify-between mb-12">
      <div>
        <p class="section-label mb-3">Curriculum Vitae</p>
        <h1 class="text-3xl font-semibold text-zinc-900 dark:text-zinc-100 tracking-tight">{cv.name}</h1>
        <p class="text-zinc-500 dark:text-zinc-400 mt-1">{cv.title} &middot; {cv.location}</p>
      </div>
    </div>

    <p class="text-zinc-600 dark:text-zinc-400 leading-relaxed mb-16 max-w-xl">{cv.summary}</p>

    <!-- Education -->
    <section class="mb-14">
      <p class="section-label mb-6">Education</p>
      <div class="space-y-8">
        {cv.education.map((edu) => (
          <div class="flex flex-col sm:flex-row gap-1 sm:gap-8">
            <span class="text-sm text-zinc-400 dark:text-zinc-500 sm:w-28 flex-shrink-0 pt-0.5">{edu.period}</span>
            <div>
              <p class="font-semibold text-zinc-900 dark:text-zinc-100">{edu.degree}</p>
              <p class="text-zinc-600 dark:text-zinc-400 text-sm">{edu.field}</p>
              <p class="text-zinc-500 dark:text-zinc-500 text-sm">{edu.institution}</p>
              {edu.notes && <p class="text-zinc-400 dark:text-zinc-500 text-sm mt-1 italic">{edu.notes}</p>}
            </div>
          </div>
        ))}
      </div>
    </section>

    <div class="divider mb-14"></div>

    <!-- Experience -->
    <section class="mb-14">
      <p class="section-label mb-6">Experience</p>
      <div class="space-y-10">
        {cv.experience.map((exp) => (
          <div class="flex flex-col sm:flex-row gap-1 sm:gap-8">
            <span class="text-sm text-zinc-400 dark:text-zinc-500 sm:w-28 flex-shrink-0 pt-0.5">{exp.period}</span>
            <div class="flex-1">
              <p class="font-semibold text-zinc-900 dark:text-zinc-100">{exp.role}</p>
              <p class="text-zinc-500 dark:text-zinc-400 text-sm mb-3">{exp.company} &middot; {exp.location}</p>
              <ul class="space-y-1.5">
                {exp.bullets.map((b) => (
                  <li class="text-sm text-zinc-600 dark:text-zinc-400 flex gap-2">
                    <span class="text-zinc-300 dark:text-zinc-600 flex-shrink-0 mt-1.5 select-none">—</span>
                    {b}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </section>

    <div class="divider mb-14"></div>

    <!-- Skills -->
    <section class="mb-14">
      <p class="section-label mb-6">Skills</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400 mb-3">Technical</p>
          <ul class="space-y-2">
            {cv.skills.technical.map((s) => (
              <li class="text-sm text-zinc-700 dark:text-zinc-300">{s}</li>
            ))}
          </ul>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400 mb-3">Domain</p>
          <ul class="space-y-2">
            {cv.skills.domain.map((s) => (
              <li class="text-sm text-zinc-700 dark:text-zinc-300">{s}</li>
            ))}
          </ul>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-400 mb-3">Languages</p>
          <ul class="space-y-2">
            {cv.skills.languages.map((s) => (
              <li class="text-sm text-zinc-700 dark:text-zinc-300">{s}</li>
            ))}
          </ul>
        </div>
      </div>
    </section>

  </div>
</Page>
